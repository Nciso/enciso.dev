# The public site URL used for:
#   - canonical <link>/site config (astro.config.mjs)
#   - llms.txt / llms-full.txt links (scripts/build-index.mjs)
#   - the "Continue in ChatGPT" handoff, so ChatGPT reads the REAL deployed
#     pages instead of a preview/localhost URL (src/components/Ask.tsx)
#
# Must be the full origin, no trailing slash. Must be prefixed PUBLIC_ so it is
# exposed to the browser bundle. On Vercel/Netlify/Cloudflare, set this in the
# project's environment variables. Locally, copy this file to `.env`.
PUBLIC_SITE_URL=https://enciso.dev
